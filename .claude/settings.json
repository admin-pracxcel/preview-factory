    "deny": [
      "Write(.env)",
      "Write(./.env)",
      "Edit(.env)",
      "Write(.claude/**)",
      "Edit(.claude/**)",
      "Write(autopilot/!(state)/**)",
      "Edit(autopilot/!(state)/**)",
      "Bash(stripe:*)",
      "Bash(vercel:*)",
      "Bash(gcloud:*)",
      "Bash(aws:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(npm publish:*)",
      "Bash(npm login:*)",
      "Bash(supabase db push:*)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "$comment": "Belt-and-suspenders permissions for when you use the interactive Claude Code CLI in this repo. The autopilot supervisor enforces the same rules via hooks in autopilot/guards.mjs, which apply even if these are bypassed.",
  "settingSources": [
    "project"
  ]
}
