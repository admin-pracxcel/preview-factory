{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "allowJs": true,
    "isolatedModules": false,
    "jsx": "react-jsx",
    "incremental": false
  },
  "include": ["generator/**/*.ts", "shared/types/**/*.ts"],
  "exclude": ["node_modules", "dist", "app", "templates"]
}
