# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit real keys.

# ---- Required for core features ----

# Anthropic API key — NOT REQUIRED for the web app.
# Site generation and edit engine shell out to the local `claude` CLI
# (Claude Code subscription) — no API key needed.
# ANTHROPIC_API_KEY=sk-ant-...

# Set to "1" to bypass the model entirely and use deterministic fixtures
# (generator-api: clearflow-plumbing.json; edit-engine: fixtureEdit).
# Useful for CI, offline development, and fast UI iteration.
# USE_FIXTURE=1

# Google Places API key — used by lib/places-client.ts to pull real Google Business Profile data.
# Also used to fetch business photos from the GBP for the hero/gallery.
# Enable the Places API (New) at: https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=AIza...

# Pexels API key — stock photography for generated sites. Free tier covers
# 200 req/hour, 20,000/month. No payment, no approval needed.
# Free signup: https://www.pexels.com/api/
# Used as fallback when a business has few/no GBP photos.
PEXELS_API_KEY=

# Stripe secret key — used by checkout and billing portal routes.
# Use a test-mode key (sk_test_...) for local dev: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Stripe price ID for the subscription product the checkout session creates.
# Find it under Products in the Stripe dashboard.
STRIPE_PRICE_ID=price_...

# Stripe webhook signing secret — verifies incoming webhook signatures.
# Run `stripe listen --forward-to localhost:3000/api/webhooks/stripe` to get a dev secret.
STRIPE_WEBHOOK_SECRET=whsec_...

# Base URL used for Stripe success/cancel redirects and dashboard links.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---- Supabase (Phase 2 onwards) ----

# Supabase project URL. Format: https://<project-ref>.supabase.co
# Grab from Supabase dashboard → Settings → API → Project URL.
# See supabase/README.md for the full setup checklist.
SUPABASE_URL=

# Supabase service_role key. SERVER-ONLY — bypasses RLS.
# NEVER leak to the client, never commit, never log.
# Grab from Supabase dashboard → Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=

# ---- n8n worker (Phase 4 onwards) ----

# Webhook URL of your self-hosted n8n instance's pf-generate-stub workflow.
# Grab from the "Webhook — job poke" node's Production URL.
# See n8n/build-guide-stub.md for setup.
# If unset, intake still works — the job stays queued and n8n's 30s cron
# picks it up automatically. Setting it just makes generation start faster.
N8N_WEBHOOK_URL=

# Shared secret verified by n8n on incoming webhook + used when n8n reports
# back to Vercel. Any random 32-byte base64 string. Must match WORKER_SECRET
# on the n8n side. Generate with: openssl rand -base64 32
WORKER_SHARED_SECRET=

# ---- Optional: autopilot supervisor (only if you run `npm run autopilot`) ----

# AUTOPILOT_HOST=0.0.0.0
# AUTOPILOT_PORT=8787
# AUTOPILOT_PUBLIC_URL=
# AUTOPILOT_NOTIFY_URL=
# AUTOPILOT_MAX_INCREMENTS=50
# AUTOPILOT_MODEL=claude-opus-4-7
# AUTOPILOT_SKIP_BUILD=
